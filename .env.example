# FIREBASE CONFIGURATION (PUBLIC)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# AI ENGINE (PRIVATE — backend only, never expose in frontend)
GROQ_API_KEY=your_groq_api_key

# SYNCFUSION LICENSE (VITE_ prefix = safe for frontend bundle)
VITE_SYNCFUSION_LICENSE=your_syncfusion_license_key

# DEPLOYMENT
VITE_BASE_PATH=/APIS-Academic-Intelligence-System/

# OPTIONAL — Production backend URL (Render/Railway etc.)
VITE_API_URL=https://your-backend.onrender.com
