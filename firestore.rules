rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // STRICT USER-OWNED DATA ISOLATION
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow access to all subcollections for the owner
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // CONTEXTUAL FEEDBACK (Create only for authenticated users)
    match /feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow read: if false; // Security: Users cannot read each other's feedback
    }
  }
}
