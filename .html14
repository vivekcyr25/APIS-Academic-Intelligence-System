<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Student Marks Portal</title>

    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }
        
        html,
        body {
            width: 100%;
            min-height: 100%;
        }
        
        body {
            font-family: Arial, sans-serif;
            background: #f0f2f5;
        }
        /* FULL WIDTH WRAPPER */
        
        .center-wrapper {
            width: 100%;
            background: #ffffff;
        }
        /* LOGIN AREA */
        
        #registrationSection {
            padding: 24px 4vw;
            border-bottom: 2px solid #ddd;
        }
        
        h1 {
            margin-bottom: 8px;
        }
        
        .reg-form {
            margin-top: 12px;
            max-width: 450px;
        }
        
        .reg-row {
            margin-bottom: 14px;
        }
        
        .reg-row label {
            display: block;
            font-weight: 600;
            margin-bottom: 5px;
        }
        
        .reg-row input {
            width: 100%;
            padding: 10px;
            border-radius: 6px;
            border: 1px solid #ccc;
            font-size: 15px;
        }
        
        button {
            padding: 9px 16px;
            background: #3b93f7;
            border: none;
            border-radius: 6px;
            color: #fff;
            cursor: pointer;
            font-size: 15px;
            transition: background 0.25s ease, transform 0.15s ease;
        }
        
        button:hover {
            background: #2f74c0;
            transform: translateY(-1px);
        }
        /* MAIN APP */
        
        #mainApp {
            display: none;
        }
        /* NAVBAR FULL WIDTH */
        
        .nav-bar {
            width: 100%;
            background: #1d7b2b;
            color: #ffffff;
            padding: 12px 4vw;
        }
        
        .nav-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .nav-title {
            font-size: 20px;
            font-weight: bold;
        }
        
        .nav-boxes {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 8px;
        }
        
        .nav-box {
            background: #2fa53c;
            padding: 6px 12px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 13px;
        }
        
        .nav-box:hover {
            background: #38c347;
        }
        
        #contactInfo,
        #aboutBox {
            font-size: 13px;
            margin-top: 4px;
        }
        /* MAIN CONTENT */
        
        .content-layout {
            display: flex;
            flex-wrap: wrap;
            width: 100%;
            gap: 1.5rem;
            padding: 1.5rem 4vw;
        }
        
        .left-column {
            flex: 2 1 350px;
        }
        
        .right-column {
            flex: 1 1 250px;
        }
        
        .useful-link-bar {
            background: #ffffff;
            border-radius: 8px;
            border: 1px solid #ddd;
            padding: 10px;
            margin-bottom: 12px;
        }
        
        .useful-link-bar a {
            color: #0b63c5;
            font-weight: bold;
            text-decoration: none;
        }
        
        .useful-link-bar a:hover {
            text-decoration: underline;
        }
        
        .marks-input-box {
            background: #ffffff;
            border-radius: 10px;
            border: 1px solid #ddd;
            padding: 14px;
        }
        
        .marks-row {
            display: flex;
            gap: 8px;
            margin-bottom: 10px;
            align-items: center;
        }
        
        .marks-row label {
            flex: 0 0 160px;
            font-size: 14px;
        }
        
        .marks-row input {
            flex: 1 1 auto;
            padding: 7px 8px;
            border-radius: 6px;
            border: 1px solid #ccc;
            font-size: 14px;
        }
        
        #marksMessage {
            margin-top: 8px;
            font-size: 13px;
            color: #b31515;
        }
        
        #marksTableBox {
            display: none;
            margin-top: 12px;
        }
        
        .green-box {
            background: #e1ffe5;
            border: 2px solid #1d7b2b;
            border-radius: 10px;
            padding: 10px;
        }
        
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 5px;
        }
        
        th,
        td {
            padding: 8px;
            border: 1px solid #1d7b2b;
            text-align: center;
            font-size: 14px;
            background: #ffffff;
        }
        
        th {
            background: #c8f5ce;
        }
        
        .white-box {
            background: #ffffff;
            border-radius: 10px;
            border: 1px solid #ddd;
            padding: 14px;
            font-size: 14px;
        }
        /* FOOTER */
        
        .ack-section {
            width: 100%;
            padding: 16px 4vw 20px 4vw;
            background: #ffffff;
            border-top: 1px solid #ccc;
            font-size: 14px;
        }
        /* ================== MOBILE / SMALL SCREEN (STACK EVERYTHING) ================== */
        
        @media (max-width: 768px) {
            #registrationSection {
                padding: 20px 4vw;
            }
            .nav-top {
                flex-direction: column;
                align-items: flex-start;
                gap: 4px;
            }
            .content-layout {
                flex-direction: column;
                padding: 16px 4vw;
            }
            .left-column,
            .right-column {
                flex: 1 1 100%;
            }
            .marks-row {
                flex-direction: column;
                align-items: flex-start;
            }
            .marks-row label {
                flex: 0 0 auto;
            }
            .marks-row input {
                width: 100%;
            }
        }
    </style>
</head>

<body>
    <div class="center-wrapper">

        <!-- LOGIN SECTION -->
        <section id="registrationSection">
            <h1>Login Portal</h1>
            <p>Enter your credentials to continue:</p>

            <form class="reg-form" onsubmit="handleLogin(event)">
                <div class="reg-row">
                    <label for="loginUser">Username:</label>
                    <input type="text" id="loginUser" required placeholder="Enter username" />
                </div>
                <div class="reg-row">
                    <label for="loginPass">Password:</label>
                    <input type="password" id="loginPass" required placeholder="Enter password" />
                </div>
                <button type="submit">Login</button>
            </form>
        </section>

        <!-- MAIN APP -->
        <section id="mainApp">

            <!-- NAVBAR -->
            <div class="nav-bar">
                <div class="nav-top">
                    <div class="nav-title">Student Portal</div>
                    <div id="welcomeText" style="font-size:13px;"></div>
                </div>

                <div class="nav-boxes">
                    <div class="nav-box" id="homeNav">Home</div>
                    <div class="nav-box" id="aboutNav">About</div>
                    <div class="nav-box" id="contactNav">Contact</div>
                    <div class="nav-box" id="marksNav">Marks</div>
                    <div class="nav-box" id="helpNav">Help</div>
                </div>

                <p id="contactInfo"></p>
                <p id="aboutBox" style="display:none;"></p>
            </div>

            <!-- CONTENT -->
            <div class="content-layout">

                <!-- LEFT SIDE -->
                <div class="left-column">
                    <h2>Enter Details</h2>

                    <div class="useful-link-bar">
                        Useful Link:
                        <a href="https://ums.lpu.in/lpuums/" target="_blank">Open LPU UMS</a>
                    </div>

                    <div id="marksSection" class="marks-input-box">
                        <div class="marks-row">
                            <label for="regNoInput">Registration Number:</label>
                            <input type="text" id="regNoInput" placeholder="e.g. 12510200" />
                        </div>
                        <div class="marks-row">
                            <label for="nameInput">Name:</label>
                            <input type="text" id="nameInput" placeholder="Enter your name" />
                        </div>

                        <button type="button" onclick="showMarks()">Show Marks</button>
                        <p id="marksMessage"></p>
                    </div>

                    <div id="marksTableBox">
                        <div class="green-box">
                            <h3>Marks Table</h3>
                            <table>
                                <thead>
                                    <tr>
                                        <th>Reg No</th>
                                        <th>Name</th>
                                        <th>Maths</th>
                                        <th>Physics</th>
                                        <th>Computer</th>
                                    </tr>
                                </thead>
                                <tbody id="marksBody"></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- RIGHT SIDE -->
                <div class="right-column">
                    <h2>Notes</h2>
                    <div class="white-box">
                        <p>This portal is created using HTML, CSS & JavaScript.</p>
                        <p>Search marks using the registration number. Admin can view all data.</p>
                    </div>
                </div>

            </div>

            <!-- FOOTER -->
            <div class="ack-section">
                <p>This project demonstrates a sample student marks portal.</p>
                <p>&copy; @VivekLPU 2025 – All rights reserved.</p>
            </div>

        </section>
    </div>

    <script>
        const students = [{
            regNo: "12510200",
            name: "Vivek",
            maths: 85,
            physics: 78,
            comp: 92
        }, {
            regNo: "12510201",
            name: "Harsh",
            maths: 75,
            physics: 68,
            comp: 80
        }, {
            regNo: "12510202",
            name: "Rahul",
            maths: 90,
            physics: 88,
            comp: 85
        }, {
            regNo: "12510203",
            name: "Neha",
            maths: 65,
            physics: 70,
            comp: 72
        }];

        function handleLogin(e) {
            e.preventDefault();
            const user = document.getElementById("loginUser").value.trim();
            const pass = document.getElementById("loginPass").value.trim();

            if (!user || !pass) {
                alert("Please enter both username and password.");
                return;
            }

            document.getElementById("welcomeText").textContent = "Logged in as: " + user;

            document.getElementById("registrationSection").style.display = "none";
            document.getElementById("mainApp").style.display = "block";

            setupNavEvents();
        }

        function showMarks() {
            const reg = document.getElementById("regNoInput").value.trim();
            const name = document.getElementById("nameInput").value.trim();
            const msg = document.getElementById("marksMessage");
            const body = document.getElementById("marksBody");
            const tableBox = document.getElementById("marksTableBox");

            msg.textContent = "";
            body.innerHTML = "";
            tableBox.style.display = "none";

            if (!reg || !name) {
                msg.textContent = "Please enter both fields.";
                return;
            }

            // Admin view: show all
            if (reg === "12510200" && name.toLowerCase() === "admin") {
                students.forEach(s => {
                    body.innerHTML += `
                    <tr>
                        <td>${s.regNo}</td>
                        <td>${s.name}</td>
                        <td>${s.maths}</td>
                        <td>${s.physics}</td>
                        <td>${s.comp}</td>
                    </tr>`;
                });
                tableBox.style.display = "block";
                return;
            }

            const found = students.find(s => s.regNo === reg);

            if (!found) {
                msg.textContent = "No record found.";
                return;
            }

            body.innerHTML = `
            <tr>
                <td>${found.regNo}</td>
                <td>${found.name}</td>
                <td>${found.maths}</td>
                <td>${found.physics}</td>
                <td>${found.comp}</td>
            </tr>`;
            tableBox.style.display = "block";
        }

        function setupNavEvents() {
            const homeNav = document.getElementById("homeNav");
            const aboutNav = document.getElementById("aboutNav");
            const contactNav = document.getElementById("contactNav");
            const marksNav = document.getElementById("marksNav");
            const helpNav = document.getElementById("helpNav");
            const contactInfo = document.getElementById("contactInfo");
            const aboutBox = document.getElementById("aboutBox");
            const marksSection = document.getElementById("marksSection");

            homeNav.onclick = () => window.open("https://google.com", "_blank");
            helpNav.onclick = () => window.open("https://google.com", "_blank");

            contactNav.addEventListener("mouseenter", () => {
                contactInfo.textContent = "Contact: 123-456-789-0";
            });
            contactNav.addEventListener("mouseleave", () => {
                contactInfo.textContent = "";
            });

            aboutNav.onclick = () => {
                aboutBox.style.display = "block";
                aboutBox.textContent =
                    "This is a simple HTML-based student portal created using HTML, CSS and JavaScript.";
            };

            marksNav.onclick = () => {
                marksSection.scrollIntoView({
                    behavior: "smooth"
                });
            };
        }
    </script>

</body>

</html>