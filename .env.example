# ==================================================
# APIS AI - Environment Configuration Template
# Copy this to .env and fill in the values.
# ==================================================

# --- PUBLIC CONFIG (EXPOSED TO FRONTEND) ---
# All frontend variables MUST start with VITE_

# Firebase Public Config
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Cloudflare Turnstile Public Key
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key

# Formspree Endpoint (Optional)
VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/your_id

# --- PRIVATE CONFIG (SERVER-SIDE ONLY) ---
# DO NOT prefix with VITE_. These are used by Vercel Serverless Functions.

# Gemini AI Secret (Used in /api/ai)
GEMINI_API_KEY=your_gemini_private_key

# Turnstile Secret (Used in /api/verify)
TURNSTILE_SECRET_KEY=your_turnstile_secret_key
